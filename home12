<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>聯邦藝術中心 | Union Group Art Gallery</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,700;1,500&family=Noto+Serif+TC:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-red: #E60012;
            --bg-color: #fafafa;
            --text-color: #1a1a1a;
            --font-en: 'Cormorant Garamond', serif;
            --font-zh: 'Noto Serif TC', serif;
        }

        body { 
            margin: 0; 
            background: var(--bg-color); 
            font-family: var(--font-zh); 
            color: var(--text-color); 
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* 導覽列 */
        nav {
            position: fixed;
            top: 0; right: 0;
            padding: 40px 5vw;
            z-index: 100;
            display: flex;
            gap: 25px;
            font-size: 15px;
            letter-spacing: 0.1em;
        }
        nav a { text-decoration: none; color: var(--text-color); transition: 0.3s; }
        nav a:hover { color: var(--primary-red); }

        /* 側邊垂直字母 - UNION (鋼筆風格英文字) */
        .vertical-letters {
            position: fixed; 
            left: 4vw; 
            top: 15vh; 
            font-family: var(--font-en);
            font-size: 9vw;
            font-weight: 500; 
            line-height: 0.75; 
            color: var(--primary-red);
            text-transform: uppercase; 
            z-index: 1;
            opacity: 0.9;
            user-select: none;
        }

        .content-flow { padding: 15vh 12vw 10vh 20vw; position: relative; z-index: 2; }

        /* 標題區塊 */
        .hero-section { margin-bottom: 15vh; }
        .hero-title { font-size: 42px; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.2em; }
        .hero-subtitle { font-family: var(--font-en); font-style: italic; font-size: 24px; color: #666; }
        .hero-desc { max-width: 400px; margin-top: 30px; font-size: 15px; border-left: 1px solid var(--primary-red); padding-left: 20px; }

        /* 藝術展品區塊 */
        .art-piece { position: relative; margin-bottom: 25vh; display: flex; align-items: center; }
        .art-piece.right { justify-content: flex-end; }
        .art-piece.left { justify-content: flex-start; }

        .img-wrapper { position: relative; border: 1px solid #ddd; padding: 15px; background: #fff; box-shadow: 10px 10px 0px rgba(0,0,0,0.03); }
        .art-piece img { width: 38vw; display: block; filter: grayscale(20%); transition: 0.5s; }
        .art-piece img:hover { filter: grayscale(0%); }

        /* 日式細膩文字描述 */
        .caption {
            position: absolute;
            width: 280px;
            z-index: 3;
        }
        .art-piece.right .caption { left: -100px; border-left: 1px solid var(--primary-red); padding-left: 25px; }
        .art-piece.left .caption { right: -100px; border-right: 1px solid var(--primary-red); padding-right: 25px; text-align: right; }

        .caption h3 { font-size: 20px; margin: 0 0 10px 0; letter-spacing: 0.1em; }
        .caption p { font-size: 14px; color: #444; margin: 5px 0; }
        .tag { display: inline-block; font-family: var(--font-en); font-style: italic; color: var(--primary-red); margin-bottom: 5px; }

        /* 最新消息與資訊 */
        .info-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 100px; margin-top: 10vh; }
        .news-item { border-bottom: 1px solid #eee; padding: 20px 0; display: flex; justify-content: space-between; align-items: center; text-decoration: none; color: inherit; }
        .news-date { font-family: var(--font-en); font-size: 14px; color: #999; }

        /* 頁尾 */
        footer { 
            background: #111; color: #fff; padding: 80px 10vw; 
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px;
            font-size: 14px; margin-top: 10vh;
        }
        footer h4 { color: var(--primary-red); margin-bottom: 20px; font-weight: 700; }
        footer p, footer a { color: #aaa; text-decoration: none; margin: 8px 0; display: block; }
        .copyright { grid-column: 1 / -1; margin-top: 50px; text-align: center; border-top: 1px solid #333; padding-top: 30px; font-family: var(--font-en); font-size: 12px; }

        @media (max-width: 768px) {
            .vertical-letters { display: none; }
            .content-flow { padding: 10vh 8vw; }
            .art-piece img { width: 70vw; }
            .art-piece.right .caption, .art-piece.left .caption { position: relative; left: 0; right: 0; width: 100%; margin-top: 20px; text-align: left; }
            .info-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
