    </div>

    <script>
        // 滑鼠滾輪橫向捲動
        window.addEventListener('wheel', (evt) => {
            if (evt.deltaY !== 0) {
                window.scrollBy({ left: evt.deltaY * 2, behavior: 'auto' });
            }
        });
        
        // 自動播放 (每30毫秒移動1像素)
        let autoScroll = setInterval(() => { 
            window.scrollBy({ left: 1, behavior: 'auto' }); 
        }, 30);
        
        // 使用者操作時停止自動播放
        window.addEventListener('mousedown', () => clearInterval(autoScroll));
        window.addEventListener('touchstart', () => clearInterval(autoScroll));
    </script>
</body>
</html>
