<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UNION GROUP Art Gallery | 聯邦藝術中心</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand-red: #E60012;
            --bg-gray: #fafafa;
            --text-dark: #1a1a1a;
            --text-light: #888;
        }

        body { 
            margin: 0; 
            background: var(--bg-gray); 
            font-family: "Noto Serif TC", serif; 
            overflow-x: auto;
            overflow-y: hidden;
            color: var(--text-dark);
        }

        /* 貫穿全頁的紅線軸心 */
        .horizontal-axis { 
            position: fixed; 
            top: 60%; /* 下移，確保上方有足夠空間給固定目錄 */
            left: 0; 
            width: 100%; 
            height: 1.5px; 
            background: var(--brand-red); 
            z-index: 0; 
        }

        /* 導覽列：設定為 fixed 固定在畫面左上角 */
        nav {
            position: fixed;
            top: 30px;
            left: 40px;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 30px;
            background: rgba(250, 250, 250, 0.8); /* 稍微透明背景避免遮擋 */
            padding: 10px;
            border-radius: 4px;
        }
        nav img { height: 50px; }
        .nav-links { display: flex; gap: 20px; }
        .nav-links a { 
            text-decoration: none; 
            color: var(--text-dark); 
            font-size: 14px; 
            font-weight: 700; 
            transition: 0.3s; 
        }
        .nav-links a:hover { color: var(--brand-red); }

        /* 內容容器 */
        .scroll-wrapper { 
            display: inline-flex; 
            align-items: center; 
            padding: 120px 10vw 0 10vw; 
            height: 100vh; 
            gap: 10vw;
            white-space: nowrap;
            box-sizing: border-box;
        }

        /* 基礎卡片樣式：縮小 padding 以節省空間 */
        .item { 
            position: relative; 
            z-index: 1; 
            background: #fff; 
            padding: 30px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            min-width: 280px;
        }

        /* 調整上下位移，避免超出螢幕邊界 */
        .item-up { margin-bottom: 15vh; }
        .item-down { margin-top: 35vh; }

        /* 文字風格：縮小標題字體 */
        .item h2 { font-size: 0.8rem; color: var(--brand-red); letter-spacing: 2px; margin-bottom: 8px; font-weight: 700; }
        .item h3 { font-size: 1.8rem; margin: 0; line-height: 1.2; font-weight: 900; white-space: normal; }
        .item p { font-size: 13px; letter-spacing: 0.5px; color: var(--text-light); white-space: normal; line-height: 1.5; }
        .date { font-family: "Noto Serif TC", serif; font-size: 11px; color: var(--brand-red); margin-bottom: 5px; font-weight: bold; }

        /* 頁尾標語：標準字體 */
        .script-font {
            font-family: "Noto Serif TC", serif;
            font-style: italic;
            font-weight: 700;
            font-size: 20px;
            color: var(--brand-red);
            margin-top: 20px;
            display: block;
            letter-spacing: 1px;
        }

        /* 圖片處理：縮小圖片尺寸防止溢出 */
        .item img { width: 280px; height: 280px; object-fit: cover; margin-bottom: 15px; display: block; border: 1px solid #eee; }
        .banner-img { width: 400px !important; height: 240px !important; }

        /* 連結線邏輯：縮短長度 */
        .connector { 
            position: absolute; 
            width: 1.5px; 
            background: var(--brand-red); 
            left: 50%; 
        }
        .item-up .connector { bottom: -12vh; height: 12vh; }
        .item-down .connector { top: -14vh; height: 14vh; }

        /* 頁尾資訊區 */
        .footer-info {
            padding: 40px;
            min-width: 550px;
        }
        .footer-grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 30px; white-space: normal; }
        .footer-col h4 { color: var(--brand-red); margin-bottom: 10px; font-size: 15px; border-bottom: 1px solid #eee; padding-bottom: 5px; }
        .footer-col ul { list-style: none; padding: 0; margin: 0; font-size: 12px; line-height: 1.8; color: #666; }

        body::-webkit-scrollbar { display: none; }
    </style>
</head>
<body>

    <nav>
        <img src="https://i.ibb.co/Txzm1B60/0210.jpg" alt="Logo">
        <div class="nav-links">
