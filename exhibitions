        <p>Exhibitions & Touring Schedule</p>
    </div>
</section>


<!-- ===== 搜尋區 ===== -->
<section class="content-section light-bg">
    <div class="container">
        <h2>搜尋展覽城市</h2>
        <input type="text" id="searchInput" placeholder="輸入城市名稱，例如：高雄" onkeyup="filterExhibitions()">
